                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="34" value="取得した未受信リストを受信定義に当てた結果からMDB内のテーブルを得られるので&lt;div&gt;MDB内にテーブルがあり、データが１件以上入っているか走査する。&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Noto Sans JP;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DNoto%2BSans%2BJP;" parent="1" vertex="1">
