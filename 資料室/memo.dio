                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="30" value="&lt;div&gt;MDBファイルへのアタッチをなるべく防ぐために、状況でふるいにかけてしまう。&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;EJ受注出荷売上がPIC中状況FLGが 1　で&lt;div&gt;LJ受注連携累積V2 に管理番号が存在していなければ連携は作成されたが、LWで未受信となる。&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Noto Sans JP;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DNoto%2BSans%2BJP;" parent="1" vertex="1">
