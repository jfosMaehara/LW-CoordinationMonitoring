<Window x:Class="Ui.Views.CoordinationMonitoringListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ui.Views"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        FontFamily="pack://application:,,,/MaterialDesignThemes.Wpf;component/Resources/Roboto/#Roboto"
        Title="連携モニタリング"
        Height="650"
        Width="1200">
    <materialDesign:DialogHost
        CloseOnClickAway="False"
        DialogContentUniformCornerRadius="20"
        DialogTheme="Inherit"
        Identifier="BaseDialog">
        <StackPanel Orientation="Vertical" Margin="0">
            <StackPanel Orientation="Horizontal" Margin="16">
                <TextBlock Text="確認時刻：" FontSize="32"></TextBlock>
                <TextBlock Text="{Binding CheckDateTime, StringFormat=yyyy年MM月dd日 HH:mm:ss}" FontSize="32"></TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="16">
                <DataGrid
                    MaxHeight="500"
                    MinHeight="500"
                    Height="500"
                    Width="1100"
                    VerticalScrollBarVisibility="Visible"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    HeadersVisibility="All"
                    ItemsSource="{Binding CheckResultEntities}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn
                            Header="受信取込管理番号"
                            IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Text="{Binding ReceivingCapturingManagementNumber}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn
                            Header="枝番"
                            IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Text="{Binding BranchNumber}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn
                            Header="定義名"
                            IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Text="{Binding DefinitionName}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn
                            Header="事業所CD"
                            IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Text="{Binding OfficeCD}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn
                            Header="荷主CD"
                            IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Text="{Binding ShipperCD}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn
                            Header="荷主部門CD"
                            IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Text="{Binding CustomerDeptCD}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn
                            Header="受注先CD"
                            IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Text="{Binding OrderTargetCD}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn
                            Header="状態"
                            IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Text="{Binding StatusMessage}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn
                            Header="備考"
                            IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Text="{Binding ExceptionMessage}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </StackPanel>
    </materialDesign:DialogHost>
</Window>
        
