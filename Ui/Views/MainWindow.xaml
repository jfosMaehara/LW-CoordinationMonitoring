<Window
    x:Class="Ui.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:domain="clr-namespace:Domain"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:Ui"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:validate="clr-namespace:Ui.ValidationRules"
    Title="{Binding ApplicationTitle}"
    Width="900"
    Height="900"
    Background="{DynamicResource MaterialDesignPaper}"
    FontFamily="pack://application:,,,/MaterialDesignThemes.Wpf;component/Resources/Roboto/#Roboto"
    TextElement.FontSize="14"
    TextElement.FontWeight="Medium"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    mc:Ignorable="d">

    <materialDesign:DialogHost
        CloseOnClickAway="False"
        DialogContentUniformCornerRadius="20"
        DialogTheme="Inherit"
        Identifier="BaseDialog">
        <DockPanel>
            <Grid DockPanel.Dock="Top">
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Vertical">
                        <materialDesign:ColorZone Padding="16" Mode="PrimaryMid">
                            <DockPanel>

                                <TextBlock
                                    Width="Auto"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center"
                                    DockPanel.Dock="Left"
                                    Text="{Binding ApplicationName}"
                                    TextAlignment="Left" />

                                <TextBlock
                                    Width="Auto"
                                    Margin="16,0,0,0"
                                    DockPanel.Dock="Right"
                                    FontSize="12"
                                    Text="{Binding Version}"
                                    TextAlignment="Right" />

                            </DockPanel>
                        </materialDesign:ColorZone>

                    </StackPanel>
                </StackPanel>
            </Grid>
            
            <ContentControl Content="{Binding Content}" />

        </DockPanel>
    </materialDesign:DialogHost>

</Window>
